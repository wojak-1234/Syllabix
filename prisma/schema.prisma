// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// SQLite는 Enum을 지원하지 않으므로 String으로 대체합니다.
// (관리 필요: STUDENT, TEACHER)
// enum UserRole { ... }
// enum SeriesVisibility { ... }
// enum SeriesStatus { ... }


// ── User ─────────────────────────────────────────────────────────────

model User {
  id    String   @id @default(cuid())
  email String   @unique
  name  String?
  role  String   @default("STUDENT") // STUDENT, TEACHER


  // 선생님용 관계
  series      Series[] 
  
  // 학생용 관계
  enrollments Enrollment[] 
  submissions Submission[] 
  errorNotes  ErrorNote[] 
  activities  ActivityLog[]
  blindPoints BlindPoint[]
  curriculums Curriculum[]

  // [신규] 개인화 맞춤형 프로파일링 척도
  studentLevel   String? // 수준 평가 (예: Beginner, Intermediate)
  blunderList    String? // 고질적 실수 패턴 (JSON 형식, 예: ["IndexError", "IndentError"])
  totalSolveTime Int     @default(0) // 누적 문제 풀이 시간 (초)
  accuracyRate   Float   @default(0) // 전체 정답률 (0.0 ~ 1.0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Series (커리큘럼) ── Teacher가 설계, Student가 Join ──────────────

model Series {
  id        String @id @default(cuid())
  teacherId String
  teacher   User   @relation(fields: [teacherId], references: [id])

  title       String // 커리큘럼 제목
  description String? // 커리큘럼 설명
  targetLevel String // 대상 수준 (beginner / intermediate / advanced)
  goal        String? // 목표 수강자 설정

  status     String @default("DRAFT") // DRAFT, PUBLISHED
  visibility String @default("PRIVATE") // PUBLIC, LINK_ONLY, PRIVATE


  lectures    Lecture[] // 소속 강좌 목록
  enrollments Enrollment[] // 수강 등록
  blindPoints SeriesBlindPoint[] // [신규] 강좌 전체 분석 결과

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SeriesBlindPoint {
  id              String   @id @default(cuid())
  seriesId        String
  series          Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  
  concept         String   // 취약 개념 (예: "Recursion")
  lectureTitle    String   // 분석에 사용된 대표 강의명
  failRate        Float    // 취약점 노출 실패율
  studentDifficulties String // 학생들이 겪는 어려움 (JSON stringify된 배열)
  aiDeepFeedback  String   // AI의 정밀 분석 및 교수 전략 조언
  ragAnchor       String?  // RAG 참조 구간

  createdAt       DateTime @default(now())
}

// ── Lecture (강좌) ── Series에 종속 ──────────────────────────────────

model Lecture {
  id       String @id @default(cuid())
  seriesId String
  series   Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  order             Int // 강좌 순서 (드래그로 조정)
  title             String
  learningObjective String // 학습 목표 (필수 — RAG 앵커)
  conceptTags       String // 핵심 개념 태그 (JSON 또는 쉼표 분리 문자열)
  content           String? // 강의 본문 / 스크립트 (RAG용)

  // AI 정책 설정 필드
  aiFocusPoints      String? // AI 집중 분야 (프롬프트 가이드)
  minQuizCount       Int      @default(1)
  maxQuizCount       Int      @default(3)
  minCodingTestCount Int      @default(1)
  maxCodingTestCount Int      @default(2)

  attachmentUrl     String? // 첨부파일 URL (PDF, 슬라이드)

  // 동적 생성 모델로 전환하므로 정적 Quiz/CodingTest 관계 삭제
  submissions Submission[]
  errorNotes  ErrorNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([seriesId, order])
}

// ── Enrollment (수강 등록) ── 학생이 Series를 Join ───────────────────

model Enrollment {
  id        String @id @default(cuid())
  studentId String
  student   User   @relation(fields: [studentId], references: [id])
  seriesId  String
  series    Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  currentLectureId    String? // 현재 진행 중인 강좌 ID
  completedLectureIds String // 완료한 강좌 ID 목록 (JSON stringify)
  progress            Float   @default(0) // 진도율 (0.0 ~ 1.0)


  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, seriesId])
}

// ── Quiz, CodingTest 정적 테이블은 AI 실시간 생성 기반으로 전환됨 ──

// ── Submission (코딩테스트 제출) ── 최대 3회 ─────────────────────────

model Submission {
  id           String     @id @default(cuid())
  studentId    String
  student      User       @relation(fields: [studentId], references: [id])
  
  lectureId    String
  lecture      Lecture    @relation(fields: [lectureId], references: [id], onDelete: Cascade)

  // 동적 생성 문제 메타데이터
  dynamicQuestionTitle       String?
  dynamicQuestionDescription String?
  solveTime                  Int?    // 푸는데 걸린 추가 시간 (초)

  attemptNumber Int // 시도 번호 (1, 2, 3)
  code          String // 제출한 코드 스냅샷
  passed        Boolean @default(false)
  errorType     String? // SyntaxError, TypeError, LogicError, RuntimeError
  errorMessage  String? // 에러 메시지 원문
  aiHint        String? // AI가 제공한 소크라테스 힌트

  submittedAt DateTime @default(now())
}

// ── ErrorNote (오답노트) ── 퀴즈 오답 or 코딩테스트 3회 실패 시 생성 ─

model ErrorNote {
  id        String @id @default(cuid())
  studentId String
  student   User   @relation(fields: [studentId], references: [id])

  lectureId      String
  lecture        Lecture @relation(fields: [lectureId], references: [id], onDelete: Cascade)

  problemTitle   String // 동적 문제명
  errorType      String? // 에러 유형
  wrongReason    String // 틀린 이유 (AI 분석)
  relatedConcept String // 관련 개념
  attemptCount   Int // 시도 횟수
  codeSnapshots  String? // 코드 스냅샷 배열 (JSON stringify)

  // 보충 학습 연결
  relatedLectureId String? // 관련 강좌 ID (RAG 검색 결과)
  supplementNote   String? // "이 개념을 다시 확인해보세요" + 보충 정보
  isResolved       Boolean @default(false)

  createdAt DateTime @default(now())
}

// ── ActivityLog (기존 유지) ──────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String // QUIZ_ANSWER, CODING_SUBMIT, LECTURE_VIEW
  content   String // 상세 데이터 (JSON stringify)
  lectureId String?

  createdAt DateTime @default(now())
}

// ── BlindPoint (기존 유지 — MVP "있으면 강한 것") ────────────────────

model BlindPoint {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  concept         String // 식별된 취약 개념 (예: "Closure")
  confidence      Float // AI의 분석 신뢰도
  evidence        String // 분석 근거 (어떤 로그를 기반으로 판단했는지)
  status          String   @default("DETECTED") // DETECTED, RESOLVED
  suggestedAction String? // AI의 추천 조치 (기존 강의 재수강 등)
  createdAt       DateTime @default(now())
}

// ── Curriculum (AI 제안 맞춤형 학습 마스터플랜) ──────────────────────
model Curriculum {
  id         String   @id @default(cuid())
  studentId  String
  student    User     @relation(fields: [studentId], references: [id])
  
  title      String
  totalWeeks Int
  totalHours Int
  phases     String   // 각 Phase의 구조화된 데이터 모음 (JSON stringify 포맷 저장)
  aiInsight  String

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
